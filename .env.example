# ─── Copy to .env and fill in values ────────────────────────────────────────
# This file is committed. .env is gitignored.

# ── RAG Souverain endpoint ───────────────────────────────────────────────────
RAG_BASE_URL=http://localhost:8080
RAG_TIMEOUT_S=30

# ── LLM Judge ────────────────────────────────────────────────────────────────
# "anthropic" uses Claude Haiku API (cheap, ~$0.0001/eval)
# "openai_compat" uses any OpenAI-compatible local endpoint (fully sovereign)
JUDGE_BACKEND=anthropic
ANTHROPIC_API_KEY=sk-ant-...
JUDGE_MODEL=claude-haiku-4-5-20251001

# For local judge (JUDGE_BACKEND=openai_compat):
# JUDGE_BASE_URL=http://localhost:8000/v1
# JUDGE_MODEL=qwen2.5

# ── PostgreSQL (shared with RAG or separate) ─────────────────────────────────
EVAL_POSTGRES_HOST=localhost
EVAL_POSTGRES_PORT=5433          # separate port to avoid collision with RAG DB
EVAL_POSTGRES_USER=eval
EVAL_POSTGRES_PASSWORD=changeme
EVAL_POSTGRES_DB=llm_eval

# ── Evaluation parameters ────────────────────────────────────────────────────
EVAL_BATCH_SIZE=10               # questions per batch sent to Ragas
EVAL_TESTSET_SIZE=50             # number of Q/A pairs to generate
EVAL_RAGAS_TIMEOUT_S=120

# ── Quality gates (used by CI) ───────────────────────────────────────────────
GATE_FAITHFULNESS_MIN=0.75
GATE_ANSWER_RELEVANCY_MIN=0.70
GATE_CONTEXT_PRECISION_MIN=0.65
GATE_CONTEXT_RECALL_MIN=0.60
GATE_MAX_REGRESSION_DELTA=0.05   # fail if any metric drops more than 5 % vs baseline

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=admin
